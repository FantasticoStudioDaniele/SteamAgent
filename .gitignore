# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Env & secrets (NEVER commit)
.env
*.maFile
storage_state.json

# Local data (raw + db); keep the folder but not its contents
data/*
!data/.gitkeep

# Game catalog: specific to each user (generated by `setup`/`collect-games`)
/config/games.yaml
# Demo catalog (generated by scripts/make_demo_db.py; data/demo.db is covered by data/*)
/config/games.demo.yaml

# steamguard-cli binaries downloaded separately
steamguard-*.exe
steamguard
*.maFile

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Playwright
playwright-report/
.playwright-mcp/
