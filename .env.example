# Copy to `.env` and fill in — or, more simply: `uv run steam-agent setup`.
# Do NOT commit the .env (it's already in .gitignore).

# --- Steam account DEDICATED to the bot (NOT your personal account) ---
STEAM_USERNAME=
STEAM_PASSWORD=
# authenticator's shared_secret (base64 string). OPTIONAL:
#  - with shared_secret: automatic/unattended login (TOTP) → suitable for the server
#  - without: use `steam-agent login --headed` and enter the code by hand
STEAM_SHARED_SECRET=

# --- Partner/publisher ID (needed for the SALES reports) ---
# Leave it empty: `setup` auto-detects it from the portal after login.
STEAM_PARTNER_ID=
# Studio name shown in the dashboard (optional, detected by `setup`).
STUDIO_NAME=

# --- Steamworks publisher Web API key (optional) ---
STEAM_PUBLISHER_API_KEY=

# --- Claude API (LLM features, optional) ---
ANTHROPIC_API_KEY=

# --- Storage (default: local SQLite; in production → Postgres) ---
DATABASE_URL=sqlite:///data/steam_agent.db

# --- Public AppID for the pipeline smoke-test (440 = Team Fortress 2) ---
SMOKE_TEST_APPID=440
