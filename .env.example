# Copia in `.env` e compila — oppure, più semplice: `uv run steam-agent setup`.
# NON committare il .env (è già in .gitignore).

# --- Account Steam DEDICATO al bot (NON il tuo account personale) ---
STEAM_USERNAME=
STEAM_PASSWORD=
# shared_secret dell'authenticator (stringa base64). OPZIONALE:
#  - con shared_secret: login automatico/non presidiato (TOTP) → adatto al server
#  - senza: usa `steam-agent login --headed` e inserisci il codice a mano
STEAM_SHARED_SECRET=

# --- ID partner/publisher (serve per i report VENDITE) ---
# Lascialo vuoto: `setup` lo rileva automaticamente dal portale dopo il login.
STEAM_PARTNER_ID=
# Nome studio mostrato nella dashboard (opzionale, rilevato da `setup`).
STUDIO_NAME=

# --- Steamworks publisher Web API key (opzionale) ---
STEAM_PUBLISHER_API_KEY=

# --- Claude API (funzioni LLM, opzionale) ---
ANTHROPIC_API_KEY=

# --- Storage (default: SQLite locale; in produzione → Postgres) ---
DATABASE_URL=sqlite:///data/steam_agent.db

# --- AppID pubblico per lo smoke-test della pipeline (440 = Team Fortress 2) ---
SMOKE_TEST_APPID=440
